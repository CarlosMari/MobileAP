<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvApLocStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set anchor AP position, scan, then Start."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <!-- ① Positions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="① Set positions (metres)"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="AP:"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etApLocApX"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="X (m)"
                android:inputType="numberDecimal|numberSigned"
                android:text="0"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etApLocApY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Y (m)"
                android:inputType="numberDecimal|numberSigned"
                android:text="0"
                android:layout_marginStart="4dp"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etApLocDeltaZ"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Δz (m)"
                android:inputType="numberDecimal|numberSigned"
                android:text="1.2"
                android:layout_marginStart="4dp"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnApLocSetAp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="Phone:"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etApLocPhoneX"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="X (m)"
                android:inputType="numberDecimal|numberSigned"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etApLocPhoneY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Y (m)"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginStart="4dp"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text=" (opt)"
                android:textSize="10sp"
                android:textColor="#888888"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- ② Scan and select APs -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="② Scan and select APs"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <Button
                android:id="@+id/btnApLocScan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="Anchor:"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerApLocAnchor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="Unknown:"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerApLocUnknown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ③ Start / Stop / Reset -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="③ Start ranging"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btnApLocStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start" />

            <Button
                android:id="@+id/btnApLocStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop"
                android:enabled="false"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/btnApLocReset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reset"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Calibrate unknown AP FTM -->
        <Button
            android:id="@+id/btnApLocCalibrateUnknown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calibrate Unknown AP FTM"
            android:layout_marginBottom="6dp" />

        <!-- Waypoint collection -->
        <Button
            android:id="@+id/btnApLocSetWaypoint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SET WAYPOINT  (records phone pos + ranges unknown AP)"
            android:textSize="12sp"
            android:backgroundTint="#E53935"
            android:enabled="false"
            android:layout_marginBottom="2dp" />

        <ScrollView
            android:id="@+id/svApLocWaypointLog"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvApLocWaypointLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No waypoints yet."
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:padding="4dp" />
        </ScrollView>

        <!-- Estimate -->
        <Button
            android:id="@+id/btnApLocEstimate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESTIMATE UNKNOWN AP POSITION  (needs ≥ 3 waypoints)"
            android:textSize="12sp"
            android:backgroundTint="#7B1FA2"
            android:enabled="false"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tvApLocEstimateResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#7B1FA2"
            android:layout_marginBottom="4dp" />

        <!-- Live readouts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvApLocPosition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pos: ---"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvApLocDistance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FTM: ---"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvApLocHeading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---"
            android:textSize="11sp"
            android:textColor="#888888"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvApLocLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#888888" />
    </LinearLayout>

    <!-- Plot fills remaining space -->
    <com.group2.wififtm.TrajectoryView
        android:id="@+id/apLocTrajectoryView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
