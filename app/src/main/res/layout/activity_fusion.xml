<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Controls (compact, fixed height) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Status line -->
        <TextView
            android:id="@+id/tvFusionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Face AP direction, then tap Start."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <!-- ── STEP 1: Positions ─────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="① Set positions (metres)"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="AP:"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etApX"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="X (m)"
                android:inputType="numberDecimal|numberSigned"
                android:text="0"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etApY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Y (m)"
                android:inputType="numberDecimal|numberSigned"
                android:text="0"
                android:layout_marginStart="4dp"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSetAp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="Phone:"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPhoneX"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="X (m)"
                android:inputType="numberDecimal|numberSigned"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etPhoneY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Y (m)"
                android:inputType="numberDecimal|numberSigned"
                android:layout_marginStart="4dp"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text=" (optional)"
                android:textSize="10sp"
                android:textColor="#888888"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- ── STEP 2: Scan ──────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="② Scan and select AP"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btnFusionScan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan" />

            <Spinner
                android:id="@+id/spinnerFusionAP"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- ── STEP 3: Heading reference ────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="③ Point trolley toward AP, then tap Start"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#CC6600"
            android:layout_marginBottom="3dp" />

        <!-- ── STEP 4: Start / Stop / Cal / Reset ───────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="④ Start ranging"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="3dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnFusionStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start" />

            <Button
                android:id="@+id/btnFusionStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop"
                android:enabled="false"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/btnFusionCalibrate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cal."
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/btnFusionReset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reset"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Waypoint marker -->
        <TextView
            android:id="@+id/tvFusionWaypointNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next: WP 1 → (3.5, 0.0)  [START]"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#0055CC"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />

        <Button
            android:id="@+id/btnFusionMarkWaypoint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MARK WAYPOINT"
            android:textSize="14sp"
            android:backgroundTint="#E53935"
            android:enabled="false"
            android:layout_marginBottom="4dp" />

        <!-- Results -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvFusionPosition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pos: ---"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvFusionDistance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FTM: ---"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFusionParticles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---"
            android:textSize="11sp"
            android:textColor="#888888"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvFusionLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#888888" />
    </LinearLayout>

    <!-- Trajectory canvas fills remaining space -->
    <com.group2.wififtm.TrajectoryView
        android:id="@+id/fusionTrajectoryView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
